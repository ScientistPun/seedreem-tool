  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ScientistPun/seedreem-tool.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
